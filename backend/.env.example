SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# SSAFY GMS API
GMS_API_KEY=your-gms-api-key-here
GMS_API_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1/chat/completions
GMS_MODEL=gpt-4o

# OAuth
FRONTEND_URL=http://localhost:5173
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret-if-enabled
KAKAO_REDIRECT_URI=http://localhost:8000/api/accounts/oauth/kakao/callback/
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_REDIRECT_URI=http://localhost:8000/api/accounts/oauth/naver/callback/
